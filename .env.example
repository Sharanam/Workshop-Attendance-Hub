# Basic Auth Credentials
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=some-secure-password

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
# The callback URI configured in Google Developer Console
GOOGLE_REDIRECT_URI=https://your-app-domain.vercel.app/api/auth/callback

# Session Cookie Encryption Secret
# Use a random 32-character (or hex) string
SESSION_SECRET=a_very_long_secure_session_secret_32_chars_or_more

# Vercel Postgres Connection String (Automatically injected by Vercel when linked)
POSTGRES_URL=postgres://default:password@ep-host.us-east-1.postgres.vercel-storage.com/neondb?sslmode=require
